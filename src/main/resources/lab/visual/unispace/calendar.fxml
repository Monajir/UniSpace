<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.layout.StackPane?>
<BorderPane prefHeight="600.0" prefWidth="960.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lab.visual.unispace.controllers.CalendarController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="glass-card">
            <children>
                <Button onAction="#onBack" styleClass="secondary-button" text="← Back" />
                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label fx:id="classInfoLabel" styleClass="title-medium" text="Physics Lab (A-101)" />
                        <Label styleClass="body-text" text="Weekly Schedule Overview" />
                    </children>
                </VBox>
                <VBox alignment="CENTER_RIGHT" spacing="8.0">
                    <children>
                        <HBox spacing="12.0">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="6.0">
                                    <children>
                                        <Region prefHeight="12.0" prefWidth="12.0" styleClass="status-available" />
                                        <Label styleClass="body-text" text="Available" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="6.0">
                                    <children>
                                        <Region prefHeight="12.0" prefWidth="12.0" styleClass="status-booked" />
                                        <Label styleClass="body-text" text="Booked" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="6.0">
                                    <children>
                                        <Region prefHeight="12.0" prefWidth="12.0" styleClass="status-pending" />
                                        <Label styleClass="body-text" text="Pending" />
                                    </children>
                                </HBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
            <padding>
                <Insets bottom="20.0" left="32.0" right="32.0" top="20.0" />
            </padding>
         <BorderPane.margin>
            <Insets left="5.0" right="5.0" top="5.0" />
         </BorderPane.margin>
        </HBox>
    </top>
    <center>
        <VBox spacing="16.0" styleClass="modern-card">
            <children>
                <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="AS_NEEDED" style="-fx-background-color: #fcfcfe;" vbarPolicy="AS_NEEDED">
                    <content>
                        <GridPane fx:id="calendarGrid" hgap="8.0" vgap="8.0">
                            <padding>
                                <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                            </padding>
                        </GridPane>
                    </content>
                </ScrollPane>
            </children>
            <VBox.margin>
                <Insets bottom="32.0" left="32.0" right="32.0" top="16.0" />
            </VBox.margin>
         <BorderPane.margin>
            <Insets top="10.0" />
         </BorderPane.margin>
        </VBox>
    </center>
</BorderPane>
