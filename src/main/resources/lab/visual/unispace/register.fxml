<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="960.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lab.visual.unispace.controllers.RegisterController">

    <!-- Top bar with Back to Home button -->
    <top>
        <HBox spacing="10" styleClass="top-bar">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <children>
                <Button onAction="#goToHome" styleClass="secondary-button" text="← Home">
               <HBox.margin>
                  <Insets left="5.0" top="15.0" />
               </HBox.margin></Button>
                <Region HBox.hgrow="ALWAYS" />
            </children>
        </HBox>
    </top>

    <center>
        <StackPane>
            <VBox alignment="CENTER" maxHeight="600" maxWidth="450" spacing="24" styleClass="glass-card">
                <padding>
                    <Insets bottom="30" left="30" right="30" top="30" />
                </padding>
                <children>
                    <VBox alignment="CENTER" spacing="8">
                        <children>
                            <Label styleClass="title-large" text="Create Account" />
                            <Label styleClass="body-text" text="Join us to start booking classrooms" />
                        </children>
                  <VBox.margin>
                     <Insets />
                  </VBox.margin>
                    </VBox>

                    <VBox maxWidth="Infinity" spacing="16">
                        <children>
                            <VBox maxWidth="Infinity" spacing="6">
                                <children>
                                    <Label styleClass="subtitle" text="Username" />
                                    <TextField fx:id="usernameField" maxWidth="Infinity" promptText="Choose a username" styleClass="modern-text-field" />
                                </children>
                            </VBox>

                            <VBox maxWidth="Infinity" spacing="6">
                                <children>
                                    <Label styleClass="subtitle" text="Password" />
                                    <PasswordField fx:id="passwordField" maxWidth="Infinity" promptText="Create a password" styleClass="modern-text-field" />
                                </children>
                            </VBox>

                            <VBox maxWidth="Infinity" spacing="6">
                                <children>
                                    <Label styleClass="subtitle" text="Confirm Password" />
                                    <PasswordField fx:id="confirmPasswordField" maxWidth="Infinity" promptText="Confirm your password" styleClass="modern-text-field" />
                                </children>
                            </VBox>
                        </children>
                    </VBox>

                    <Label fx:id="errorLabel" styleClass="error-label" />

                    <VBox maxWidth="Infinity" spacing="12">
                        <children>
                            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onRegister" styleClass="primary-button" text="Create Account" />
                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                <Label styleClass="subtitle" style="-fx-font-size: 12;" text="Already have an account?"/>
                                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onBack" styleClass="secondary-button" style="-fx-font-size: 12; -fx-border-width: 0;" text="Back to Login" />
                            </HBox>
                        </children>
                    </VBox>
                </children>
            <StackPane.margin>
               <Insets bottom="5.0" top="5.0" />
            </StackPane.margin>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
