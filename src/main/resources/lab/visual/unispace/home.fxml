<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="660.0" prefWidth="960.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lab.visual.unispace.controllers.HomeController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="glass-card">
            <HBox.margin>
                <Insets bottom="12" left="8" right="8" top="24" />
            </HBox.margin>
            <children>
                <VBox spacing="4.0">
                    <Label styleClass="title-large" text="UniSpace" />
                    <Label styleClass="subtitle" text="Your smart campus assistant" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_RIGHT" spacing="8.0">
                    <!-- <Label styleClass="subtitle" text="Welcome back!" /> -->
                    <Button onAction="#onLoginButton" styleClass="primary-button" text="Login"/>
                </VBox>
            </children>
            <padding>
                <Insets bottom="20.0" left="32.0" right="32.0" top="20.0" />
            </padding>
            <BorderPane.margin>
                <Insets left="5.0" right="5.0" top="10.0" />
            </BorderPane.margin>
        </HBox>
    </top>
    <center>
        <VBox alignment="TOP_CENTER" spacing="24.0">
            <children>
                <VBox alignment="CENTER" maxWidth="600.0" spacing="12.0" styleClass="modern-card">
                    <children>
                        <Label styleClass="title-medium" text="Find Your Classroom" />
                        <TextField fx:id="searchField" promptText="Search by building or room number..." styleClass="modern-text-field" />
                    </children>
                </VBox>
                <VBox spacing="16.0" styleClass="modern-card" VBox.vgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <Label styleClass="title-medium" text="Available Classrooms" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label fx:id="roomCountLabel" styleClass="subtitle" text="3 rooms found" />
                            </children>
                        </HBox>
                        <ListView fx:id="classroomList" prefHeight="400.0" styleClass="modern-list-view" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>
            </children>
            <padding>
                <Insets bottom="32.0" left="32.0" right="32.0" top="24.0" />
            </padding>
        </VBox>
    </center>
</BorderPane>
